    @Test
    public void testToString() {
        Method method = AutoGradeUtil.ensureMethod(AutoGradeUtil.ensureClass("Student"), "toString", new Class<?>[] {});
        for (int i = 0; i < 100; i++) {
            Random random = new Random();
            Object y = 65 + (new int[]{0, 1, 2, 3, 5})[random.nextInt(5)];
            Object x = random.ints(10, 0, 3).mapToObj(j -> (new String[]{"abc", "def", "ghi"})[j]).collect(Collectors.toList()).get(0);
            SpyStudent spy = new SpyStudent((String) x, 91.0 - ((int) y - 65) * 10.0);
            try {
                Assertions.assertEquals(x + " (" + (91 - ((int) y - 65) * 10) + ".00)", method.invoke(spy));
            } catch (InvocationTargetException | IllegalAccessException e) {
                fail(String.format(
                        "Error calling method '%s.%s'.",
                        method.getDeclaringClass().getName(),
                        method.getName()
                ));
            }
        }
    }

    @Test
    public void testEquals() {
        for (int i = 0; i < 100; i++) {
            Random random = new Random();
            Object y = 65 + (new int[]{0, 1, 2, 3, 5})[random.nextInt(5)];
            List l = random.ints(10, 0, 3).mapToObj(j -> (new String[]{"abc", "def", "ghi"})[j]).collect(Collectors.toList());
            Object x = l.get(0);
            SpyStudent spy = new SpyStudent((String) x, 91.0 - ((int) y - 65) * 10.0);
            Object b = 65 + (new int[]{0, 1, 2, 3, 5})[random.nextInt(5)];
            Student sa = new Student(null, 91.0 - ((int) b - 65) * 10.0);
            Student sb = new Student((String) x, 91.0 - ((int) y - 65) * 10.0);
            Student sc = new Student(null, 91.0 - ((int) b - 65) * 10.0);
            Assertions.assertEquals(spy, spy);
            Assertions.assertEquals(spy, sb);
            Assertions.assertNotEquals(sb, sa);
            Assertions.assertEquals(sa, sc);
        }
    }


    @Test
    public void testHashCode() {
        for (int i = 0; i < 100; i++) {
            Random random = new Random();
            Object y = 65 + (new int[]{0, 1, 2, 3, 5})[random.nextInt(5)];
            List l = random.ints(10, 0, 3).mapToObj(j -> (new String[]{"abc", "def", "ghi"})[j]).collect(Collectors.toList());
            Object x = l.get(0);
            SpyStudent spy = new SpyStudent((String) x, 91.0 - ((int) y - 65) * 10.0);
            Object b = 65 + (new int[]{0, 1, 2, 3, 5})[random.nextInt(5)];
            Student sa = new Student(null, 91.0 - ((int) b - 65) * 10.0);
            Student sb = new Student((String) x, 91.0 - ((int) y - 65) * 10.0);
            Student sc = new Student(null, 91.0 - ((int) b - 65) * 10.0);
            Assertions.assertEquals(spy.hashCode(), spy.hashCode());
            Assertions.assertEquals(spy.hashCode(), sb.hashCode());
            Assertions.assertNotEquals(sb.hashCode(), sa.hashCode());
            Assertions.assertEquals(sa.hashCode(), sc.hashCode());
        }
    }

    @Test
