    @Test
    public void testStaticGetLetterGrade() {
        Method method = AutoGradeUtil.ensureMethod(AutoGradeUtil.ensureClass("StudentUtil"), "getLetterGrade", new Class<?>[] {Student.class});
        for (int i = 0; i < 100; i++) {
            Random random = new Random();
            Object y = 65 + (new int[]{0, 1, 2, 3, 5})[random.nextInt(5)];
            Object x = random.ints(10, 0, 3).mapToObj(j -> (new String[]{"abc", "def", "ghi"})[j]).collect(Collectors.toList()).get(0);
            SpyStudent spy = new SpyStudent((String) x, 91.0 - ((int) y - 65) * 10.0);
            try {
                Assertions.assertEquals((char) ((Integer) y).intValue(), method.invoke(null, spy), "%f grade".formatted(90.0 - ((int) y - 65) * 10.0));
            } catch (InvocationTargetException | IllegalAccessException e) {
                fail(String.format(
                        "Error calling method '%s.%s'.",
                        method.getDeclaringClass().getName(),
                        method.getName()
                ));
            }
            Assertions.assertEquals(spy.getCalls("getLetterGrade"), 0, "Static method should not call instance method.");
            Assertions.assertTrue(spy.getCalls("getGrade") > 0, "Static method should use getter.");
        }
    }
