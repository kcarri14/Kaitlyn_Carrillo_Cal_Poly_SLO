import org.junit.jupiter.api.Assertions;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.params.ParameterizedTest;
import org.junit.jupiter.params.provider.Arguments;
import org.junit.jupiter.params.provider.MethodSource;

import java.io.ByteArrayOutputStream;
import java.io.PrintStream;
import java.lang.reflect.InvocationTargetException;
import java.lang.reflect.Method;
import java.util.List;
import java.util.Random;
import java.util.stream.Collectors;
import java.util.stream.Stream;

import static org.junit.jupiter.api.Assertions.fail;

public class AutoGradeTests {

    private static Stream<String> provideTestClassExistsArguments() {
        return Stream.of(
                "Lab1"
        );
    }

    private static Stream<Arguments> provideTestMethodExistsArguments() {
        return Stream.of(
            Arguments.of(
                    "Lab1",
                    "main",
                    new String[] {"public", "static"},
                    void.class,
                    new Class<?>[] {String[].class}
            ),
            Arguments.of(
                    "Lab1",
                    "contains",
                    new String[] {"public", "static"},
                    boolean.class,
                    new Class<?>[] {List.class, String.class}
            )
        );
    }

    @ParameterizedTest
    @MethodSource("provideTestClassExistsArguments")
    public void testClassExists(String className) {
        AutoGradeUtil.ensureClass(className);
    }

    @ParameterizedTest
    @MethodSource("provideTestMethodExistsArguments")
    public void testMethodExists(
            String className,
            String methodName,
            String[] expectedModifiers,
            Class<?> expectedReturnType,
            Class<?>[] expectedParameterTypes
    ) {
        Class<?> clazz = AutoGradeUtil.ensureClass(className);
        Method method = AutoGradeUtil.ensureMethod(clazz, methodName, expectedParameterTypes);
        AutoGradeUtil.ensureMethodModifiers(method, expectedModifiers);
        AutoGradeUtil.ensureMethodReturnType(method, expectedReturnType);
    }

    @Test
    public void testContains() {
        Method method = AutoGradeUtil.ensureMethod(AutoGradeUtil.ensureClass("Lab1"), "contains", new Class<?>[] {List.class, String.class});

        for (int i = 0; i < 100; ++i) {
            Random random = new Random();
            Object y = (new String[]{"abc", "def", "ghi"})[random.nextInt(3)];
            Object x = random.ints(10, 0, 3).mapToObj(j -> (new String[]{"abc", "def", "ghi"})[j]).collect(Collectors.toList());
            try {
                Assertions.assertEquals(
                        method.invoke(null, x, y),
                        ((List) x).stream().anyMatch(j -> j.equals(y)),
                        String.format(
                            "Method '%s.%s' functionality error.",
                            method.getDeclaringClass().getName(),
                            method.getName()
                        )
                );
            } catch (InvocationTargetException | IllegalAccessException e) {
                fail(String.format(
                        "Error calling method '%s.%s'.",
                        method.getDeclaringClass().getName(),
                        method.getName()
                ));
            }
        }
    }

    @Test
    public void testMainOutput() {
        // Get Main Method
        Method main = AutoGradeUtil.ensureMethod(AutoGradeUtil.ensureClass("Lab1"), "main", new Class<?>[] {String[].class});

        // Record Streams
        ByteArrayOutputStream outContent = new ByteArrayOutputStream();
        PrintStream originalOut = System.out;

        // Setup
        System.setOut(new PrintStream(outContent));

        // Run
        try {
            main.invoke(null, (Object) new String[]{});
        } catch (InvocationTargetException | IllegalAccessException e) {
            fail(String.format(
                    "Error calling method '%s.%s'.",
                    main.getDeclaringClass().getName(),
                    main.getName()
            ));
        }

        // Cleanup
        System.setOut(originalOut);

        // Test
        String expectedOutput = Stream.of("x: 3",
                "y: 4.0",
                "z: 5",
                "jello",
                "Bye bye, Mochi! Farewell!"
        ).map(x -> x + System.lineSeparator()).reduce("", String::concat);

        Assertions.assertEquals(outContent.toString(), expectedOutput);
    }

}