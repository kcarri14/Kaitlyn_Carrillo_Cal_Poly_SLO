    @ParameterizedTest
    @MethodSource("provideTestParserArguments")
    public void testParser(
            String className,
            String string
    ) {
        Class<?> clazz = AutoGradeUtil.ensureClass(className);

        ImageLibrary imageLibrary = new ImageLibrary(ImageLibrary.createImageColored(32, 32, 0x808080));

        Actor actor = WorldParser.parseActor(string, imageLibrary);

        Assertions.assertInstanceOf(
                clazz,
                actor,
                String.format("WorldParser.parseActor does not instantiate class '%s'", clazz.getName())
        );
    }
